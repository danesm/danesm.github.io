---
/**
 * Individual blog post page - renders Markdown content with BaseLayout
 * Validates Requirements: 7.3
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import EmojiReactions from '../../components/EmojiReactions.astro';
import BlogCoverBanner from '../../components/BlogCoverBanner.astro';
import '../../styles/global.css';
import { generateCanonicalURL } from '../../utils/seo/meta';
import { generateArticleSchema } from '../../utils/seo/structured-data';
import { SEO_CONFIG } from '../../utils/seo/config';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const canonicalURL = generateCanonicalURL(SEO_CONFIG.siteUrl, `/blog/${post.slug}/`);

const articleSchema = generateArticleSchema({
  title: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  url: canonicalURL,
  tags: post.data.tags,
  authorName: SEO_CONFIG.siteName,
  authorUrl: SEO_CONFIG.siteUrl,
});
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalURL={canonicalURL}
  ogType="article"
>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <div class="page-wrapper">
    <Header currentPath="/blog" />

    <main id="main-content" role="main">
      <article class="blog-post">
        <div class="post-container">
          <a href="/blog" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="19" y1="12" x2="5" y2="12" />
              <polyline points="12 19 5 12 12 5" />
            </svg>
            Back to Blog
          </a>

          <BlogCoverBanner
            coverImage={post.data.coverImage}
            logoImage={post.data.logoImage}
            title={post.data.title}
            tags={post.data.tags}
          />

          <header class="post-header">
            <time class="post-date" datetime={post.data.date.toISOString()}>
              {formattedDate}
            </time>
            <h1 class="post-title">{post.data.title}</h1>
            <p class="post-description">{post.data.description}</p>

            {post.data.tags.length > 0 && (
              <div class="post-tags" aria-label={`Tags: ${post.data.tags.join(', ')}`}>
                {post.data.tags.map((tag) => (
                  <span class="post-tag">{tag}</span>
                ))}
              </div>
            )}
          </header>

          <div class="post-content prose">
            <Content />
          </div>

          <EmojiReactions slug={post.slug} />

          <footer class="post-footer">
            <a href="/blog" class="back-link">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="19" y1="12" x2="5" y2="12" />
                <polyline points="12 19 5 12 12 5" />
              </svg>
              Back to Blog
            </a>
          </footer>
        </div>
      </article>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .blog-post {
    flex: 1;
    padding: 2rem 1rem 3rem;
  }

  @media (min-width: 640px) {
    .blog-post {
      padding: 3rem 1.5rem 4rem;
    }
  }

  @media (min-width: 1024px) {
    .blog-post {
      padding: 4rem 2rem 5rem;
    }
  }

  .post-container {
    max-width: 760px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    margin-left: -0.75rem;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  .back-link:hover {
    background-color: rgba(37, 99, 235, 0.08);
  }

  .back-link:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  :global(.dark) .back-link {
    color: #93c5fd;
  }

  :global(.dark) .back-link:hover {
    background-color: rgba(147, 197, 253, 0.1);
  }

  .post-header {
    margin: 2rem 0 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  :global(.dark) .post-header {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .post-date {
    display: block;
    font-size: 0.875rem;
    font-weight: 500;
    color: #6b7280;
    margin-bottom: 0.75rem;
  }

  :global(.dark) .post-date {
    color: #9ca3af;
  }

  .post-title {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.2;
    color: #111827;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
  }

  @media (min-width: 768px) {
    .post-title {
      font-size: 2.5rem;
    }
  }

  :global(.dark) .post-title {
    color: #f9fafb;
  }

  .post-description {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #6b7280;
    margin: 0 0 1.25rem;
  }

  :global(.dark) .post-description {
    color: #9ca3af;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .post-tag {
    display: inline-block;
    padding: 0.2rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #2563eb;
    background-color: rgba(37, 99, 235, 0.08);
    border-radius: 9999px;
    letter-spacing: 0.02em;
  }

  :global(.dark) .post-tag {
    color: #93c5fd;
    background-color: rgba(147, 197, 253, 0.1);
  }

  /* Prose styles for rendered Markdown */
  .prose {
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #374151;
  }

  :global(.dark) .prose {
    color: #d1d5db;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    margin: 2.5rem 0 1rem;
    letter-spacing: -0.02em;
  }

  :global(.dark) .prose :global(h2) {
    color: #f3f4f6;
  }

  .prose :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    color: #111827;
    margin: 2rem 0 0.75rem;
  }

  :global(.dark) .prose :global(h3) {
    color: #f3f4f6;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
  }

  .prose :global(a) {
    color: #2563eb;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .prose :global(a:hover) {
    color: #1d4ed8;
  }

  :global(.dark) .prose :global(a) {
    color: #93c5fd;
  }

  :global(.dark) .prose :global(a:hover) {
    color: #bfdbfe;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.375rem;
  }

  .prose :global(code) {
    font-family: 'Fira Code', 'Consolas', monospace;
    font-size: 0.875em;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    background-color: rgba(107, 114, 128, 0.1);
    color: #1e3a8a;
  }

  :global(.dark) .prose :global(code) {
    background-color: rgba(156, 163, 175, 0.15);
    color: #93c5fd;
  }

  .prose :global(pre) {
    margin: 0 0 1.5rem;
    padding: 1.25rem;
    border-radius: 12px;
    background-color: #1e293b;
    overflow-x: auto;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  :global(.dark) .prose :global(pre) {
    background-color: rgba(15, 23, 42, 0.8);
    border-color: rgba(255, 255, 255, 0.08);
  }

  .prose :global(pre code) {
    padding: 0;
    border-radius: 0;
    background-color: transparent;
    color: #e2e8f0;
    font-size: 0.8125rem;
    line-height: 1.7;
  }

  .prose :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 3px solid #2563eb;
    background-color: rgba(37, 99, 235, 0.04);
    border-radius: 0 8px 8px 0;
    font-style: italic;
    color: #4b5563;
  }

  :global(.dark) .prose :global(blockquote) {
    border-left-color: #60a5fa;
    background-color: rgba(96, 165, 250, 0.06);
    color: #9ca3af;
  }

  .prose :global(hr) {
    margin: 2rem 0;
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  :global(.dark) .prose :global(hr) {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .prose :global(strong) {
    font-weight: 600;
    color: #111827;
  }

  :global(.dark) .prose :global(strong) {
    color: #f3f4f6;
  }

  .prose :global(table) {
    width: 100%;
    margin: 1.5rem 0;
    border-collapse: collapse;
    font-size: 0.9375rem;
  }

  .prose :global(th),
  .prose :global(td) {
    padding: 0.625rem 0.875rem;
    border: 1px solid rgba(0, 0, 0, 0.1);
    text-align: left;
  }

  :global(.dark) .prose :global(th),
  :global(.dark) .prose :global(td) {
    border-color: rgba(255, 255, 255, 0.1);
  }

  .prose :global(th) {
    font-weight: 600;
    background-color: rgba(0, 0, 0, 0.03);
    color: #111827;
  }

  :global(.dark) .prose :global(th) {
    background-color: rgba(255, 255, 255, 0.05);
    color: #f3f4f6;
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  :global(.dark) .post-footer {
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  @media (prefers-reduced-motion: reduce) {
    .back-link {
      transition: none;
    }
  }
</style>
