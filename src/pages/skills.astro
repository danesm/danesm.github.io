---
// Skills page - displays all skills organized by category
// Validates Requirements: 2.1, 2.2, 2.3, 2.4, 2.5

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SkillCard from '../components/SkillCard.astro';
import { skillsData } from '../data/skills';
import '../styles/global.css';

const skillCategories = skillsData.categories;
---

<BaseLayout
  title="Skills"
  description="Skills and expertise of Danesh Mishra — cloud architecture, AWS services, programming languages, frameworks, and DevOps tooling."
>
  <div class="page-wrapper">
    <Header currentPath="/skills" />

    <main id="main-content" role="main">
      <section class="skills-hero" aria-label="Skills introduction">
        <div class="section-container">
          <h1 class="page-title">
            <span class="heading-accent" aria-hidden="true">//</span>
            Skills & Expertise
          </h1>
          <p class="page-description">
            Technologies, platforms, and tools I work with across cloud architecture, development, and infrastructure.
          </p>
        </div>
      </section>

      <section class="skills-section" aria-label="Skills by category">
        <div class="section-container">
          <div class="skills-categories">
            {skillCategories.map((category) => (
              <div class="skill-category">
                <h2 class="category-name">{category.name}</h2>
                <div class="skills-grid">
                  {category.skills.map((skill) => (
                    <SkillCard skill={skill} category={category.name} />
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .section-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .section-container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .section-container {
      padding: 0 2rem;
    }
  }

  .skills-hero {
    padding: 3rem 0 1.5rem;
  }

  @media (min-width: 640px) {
    .skills-hero {
      padding: 4rem 0 2rem;
    }
  }

  .page-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: 2.25rem;
    }
  }

  :global(.dark) .page-title {
    color: #f9fafb;
  }

  .heading-accent {
    color: #2563eb;
    font-family: 'Fira Code', monospace;
    font-weight: 400;
    opacity: 0.6;
  }

  :global(.dark) .heading-accent {
    color: #60a5fa;
  }

  .page-description {
    font-size: 1rem;
    line-height: 1.7;
    color: #6b7280;
    margin: 0;
    max-width: 60ch;
  }

  @media (min-width: 768px) {
    .page-description {
      font-size: 1.0625rem;
    }
  }

  :global(.dark) .page-description {
    color: #9ca3af;
  }

  .skills-section {
    padding: 1.5rem 0 3rem;
    flex: 1;
  }

  @media (min-width: 640px) {
    .skills-section {
      padding: 2rem 0 4rem;
    }
  }

  @media (min-width: 1024px) {
    .skills-section {
      padding: 2rem 0 5rem;
    }
  }

  .skills-categories {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .skill-category {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .category-name {
    font-size: 1.125rem;
    font-weight: 600;
    color: #374151;
    margin: 0;
    letter-spacing: -0.01em;
  }

  :global(.dark) .category-name {
    color: #d1d5db;
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }
</style>
