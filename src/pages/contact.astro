---
/**
 * Contact page - business inquiry form + social links
 * Validates Requirements: 1.1, 1.2, 1.3, 1.4, 1.5, 1.6
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import { professionalInfo } from '../data/professional';
import '../styles/global.css';

// Social link icons (same SVGs used in Footer.astro)
const socialIcons: Record<string, string> = {
  linkedin: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  github: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  youtube: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  twitter: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
};

function getSocialIcon(platform: string): string {
  return socialIcons[platform] || '';
}

function getPlatformLabel(platform: string): string {
  const labels: Record<string, string> = {
    linkedin: 'LinkedIn',
    github: 'GitHub',
    twitter: 'X (Twitter)',
    youtube: 'YouTube',
  };
  return labels[platform] || platform.charAt(0).toUpperCase() + platform.slice(1);
}
---

<BaseLayout
  title="Contact"
  description="Get in touch with Danesh Mishra for cloud architecture consulting, AI-powered solutions, or collaboration opportunities."
>
  <div class="page-wrapper">
    <Header currentPath="/contact" />

    <main id="main-content" role="main">
      <!-- Page Header -->
      <section class="contact-hero" aria-label="Contact introduction">
        <div class="section-container">
          <h1 class="page-title">
            <span class="heading-accent" aria-hidden="true">//</span>
            Let's Connect
          </h1>
          <p class="page-description">
            Have a project in mind, need cloud architecture guidance, or want to explore a collaboration?
            I'd love to hear from you. Fill out the form below or reach out on any of my social channels.
          </p>
        </div>
      </section>

      <!-- Contact Content -->
      <section class="contact-content" aria-label="Contact form and social links">
        <div class="section-container">
          <div class="contact-grid">
            <!-- Form Column -->
            <div class="form-column">
              <h2 class="column-heading">Send a Message</h2>
              <ContactForm />
            </div>

            <!-- Info Column -->
            <div class="info-column">
              <div class="info-card">
                <h2 class="column-heading">Connect With Me</h2>
                <p class="info-text">
                  Whether it's a quick question or a detailed project brief, I typically respond within 24–48 hours.
                </p>

                <div class="social-links-list">
                  {professionalInfo.socialLinks.map((link) => (
                    <a
                      href={link.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="social-link-item"
                      aria-label={`Visit ${professionalInfo.name} on ${getPlatformLabel(link.platform)}`}
                    >
                      <span class="social-link-icon" set:html={getSocialIcon(link.platform)} />
                      <span class="social-link-details">
                        <span class="social-link-platform">{getPlatformLabel(link.platform)}</span>
                        <span class="social-link-username">@{link.username}</span>
                      </span>
                      <svg class="social-link-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="7" y1="17" x2="17" y2="7" />
                        <polyline points="7 7 17 7 17 17" />
                      </svg>
                    </a>
                  ))}
                </div>
              </div>

            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .section-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .section-container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .section-container {
      padding: 0 2rem;
    }
  }

  /* ===== PAGE HEADER ===== */
  .contact-hero {
    padding: 3rem 0 1.5rem;
  }

  @media (min-width: 640px) {
    .contact-hero {
      padding: 4rem 0 2rem;
    }
  }

  .page-title {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .page-title {
      font-size: 2.25rem;
    }
  }

  :global(.dark) .page-title {
    color: #f9fafb;
  }

  .heading-accent {
    color: #2563eb;
    font-family: 'Fira Code', monospace;
    font-weight: 400;
    opacity: 0.6;
  }

  :global(.dark) .heading-accent {
    color: #60a5fa;
  }

  .page-description {
    font-size: 1rem;
    line-height: 1.7;
    color: #6b7280;
    margin: 0;
    max-width: 60ch;
  }

  @media (min-width: 768px) {
    .page-description {
      font-size: 1.0625rem;
    }
  }

  :global(.dark) .page-description {
    color: #9ca3af;
  }

  /* ===== CONTACT CONTENT ===== */
  .contact-content {
    padding: 2rem 0 3rem;
    flex: 1;
  }

  @media (min-width: 640px) {
    .contact-content {
      padding: 2.5rem 0 4rem;
    }
  }

  @media (min-width: 1024px) {
    .contact-content {
      padding: 3rem 0 5rem;
    }
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 1.2fr 1fr;
      gap: 3.5rem;
      align-items: start;
    }
  }

  @media (min-width: 1024px) {
    .contact-grid {
      gap: 4rem;
    }
  }

  .column-heading {
    font-size: 1.125rem;
    font-weight: 600;
    color: #111827;
    margin: 0 0 1.5rem;
    letter-spacing: -0.01em;
  }

  :global(.dark) .column-heading {
    color: #f3f4f6;
  }

  /* ===== FORM COLUMN ===== */
  .form-column {
    min-width: 0;
  }

  /* ===== INFO COLUMN ===== */
  .info-column {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    padding: 1.75rem;
    border-radius: 16px;
    background-color: rgba(249, 250, 251, 0.6);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  :global(.dark) .info-card {
    background-color: rgba(31, 41, 55, 0.4);
    border-color: rgba(255, 255, 255, 0.06);
  }

  .info-text {
    font-size: 0.9375rem;
    line-height: 1.7;
    color: #6b7280;
    margin: 0 0 1.5rem;
  }

  :global(.dark) .info-text {
    color: #9ca3af;
  }

  /* ===== SOCIAL LINKS LIST ===== */
  .social-links-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .social-link-item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.875rem 1rem;
    border-radius: 12px;
    text-decoration: none;
    color: #374151;
    background-color: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(0, 0, 0, 0.06);
    transition: all 0.2s ease;
  }

  .social-link-item:hover {
    border-color: rgba(37, 99, 235, 0.25);
    background-color: rgba(37, 99, 235, 0.04);
    transform: translateX(4px);
  }

  .social-link-item:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  :global(.dark) .social-link-item {
    color: #d1d5db;
    background-color: rgba(17, 24, 39, 0.4);
    border-color: rgba(255, 255, 255, 0.06);
  }

  :global(.dark) .social-link-item:hover {
    border-color: rgba(96, 165, 250, 0.25);
    background-color: rgba(96, 165, 250, 0.06);
  }

  .social-link-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background-color: rgba(37, 99, 235, 0.08);
    color: #2563eb;
    flex-shrink: 0;
  }

  :global(.dark) .social-link-icon {
    background-color: rgba(96, 165, 250, 0.1);
    color: #93c5fd;
  }

  .social-link-details {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    flex: 1;
    min-width: 0;
  }

  .social-link-platform {
    font-size: 0.9375rem;
    font-weight: 600;
    color: #111827;
  }

  :global(.dark) .social-link-platform {
    color: #f3f4f6;
  }

  .social-link-username {
    font-size: 0.8125rem;
    color: #6b7280;
  }

  :global(.dark) .social-link-username {
    color: #9ca3af;
  }

  .social-link-arrow {
    color: #9ca3af;
    flex-shrink: 0;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s ease;
  }

  .social-link-item:hover .social-link-arrow {
    opacity: 1;
    transform: translateX(0);
    color: #2563eb;
  }

  :global(.dark) .social-link-item:hover .social-link-arrow {
    color: #93c5fd;
  }

  /* ===== AVAILABILITY CARD ===== */
  .availability-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 1.5rem;
    border-radius: 12px;
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.06), rgba(16, 185, 129, 0.04));
    border: 1px solid rgba(34, 197, 94, 0.15);
  }

  :global(.dark) .availability-card {
    background: linear-gradient(135deg, rgba(34, 197, 94, 0.08), rgba(16, 185, 129, 0.05));
    border-color: rgba(34, 197, 94, 0.2);
  }

  .availability-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #22c55e;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .availability-text {
    font-size: 0.875rem;
    font-weight: 500;
    color: #166534;
    margin: 0;
    line-height: 1.5;
  }

  :global(.dark) .availability-text {
    color: #86efac;
  }

  /* ===== SCROLL ANIMATIONS ===== */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===== REDUCED MOTION ===== */
  @media (prefers-reduced-motion: reduce) {
    .social-link-item,
    .social-link-arrow {
      transition: none;
    }

    .social-link-item:hover {
      transform: none;
    }

    .availability-dot {
      animation: none;
    }

    .animate-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  /**
   * Intersection Observer for scroll-triggered animations
   */
  function initScrollAnimations(): void {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const sections = document.querySelectorAll('.contact-hero, .contact-content');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    sections.forEach((section) => {
      section.classList.add('animate-on-scroll');
      observer.observe(section);
    });
  }

  /**
   * Track social link clicks on contact page
   */
  function initContactTracking(): void {
    document.querySelectorAll<HTMLAnchorElement>('.social-link-item').forEach((link) => {
      link.addEventListener('click', () => {
        const platform = link.querySelector('.social-link-platform')?.textContent?.trim() || 'unknown';
      });
    });
  }

  initScrollAnimations();
  initContactTracking();

  document.addEventListener('astro:after-swap', () => {
    initScrollAnimations();
    initContactTracking();
  });
</script>
