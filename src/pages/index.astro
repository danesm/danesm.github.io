</style>

<script>
  /**
   * Smooth scroll for anchor links
   */
  function initSmoothScroll(): void {
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        const href = (anchor as HTMLAnchorElement).getAttribute('href');
        if (!href || href === '#') return;

        const target = document.querySelector(href);
        if (!target) return;

        e.preventDefault();

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        target.scrollIntoView({
          behavior: prefersReducedMotion ? 'auto' : 'smooth',
          block: 'start',
        });

        history.pushState(null, '', href);
      });
    });
  }

  /**
   * Intersection Observer for fade-in animations
   */
  function initScrollAnimations(): void {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const sections = document.querySelectorAll('.services-section, .career-section, .testimonials-section, .certifications-section, .contact-section');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    sections.forEach((section) => {
      section.classList.add('animate-on-scroll');
      observer.observe(section);
    });
  }

  /**
   * Analytics event tracking for key interactive elements
   */
  function initEventTracking(): void {
    document.querySelectorAll<HTMLAnchorElement>('.contact-links .btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const platform = btn.textContent?.trim() || 'unknown';
      });
    });

    document.querySelectorAll<HTMLAnchorElement>('.hero-actions .btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const label = btn.textContent?.trim() || 'unknown';
      });
    });
  }

  /**
   * Certifications toggle - switch between curated (top 10) and all certifications
   * Validates Requirements: 6.1, 6.2
   */
  function initCertsToggle(): void {
    const toggleBtn = document.getElementById('toggle-certs');
    const certsGrid = document.getElementById('certs-grid');
    if (!toggleBtn || !certsGrid) return;

    const allCerts = (window as any).__allCertifications;
    if (!allCerts || !Array.isArray(allCerts)) return;

    let showingAll = false;

    toggleBtn.addEventListener('click', () => {
      showingAll = !showingAll;

      if (showingAll) {
        // Clear grid and render all certifications
        certsGrid.innerHTML = '';
        allCerts.forEach((cert: any) => {
          const card = document.createElement('div');
          card.className = 'badge-card';
          if (cert.credlyBadgeId) {
            const embedDiv = document.createElement('div');
            embedDiv.setAttribute('data-iframe-width', '200');
            embedDiv.setAttribute('data-iframe-height', '320');
            embedDiv.setAttribute('data-share-badge-id', cert.credlyBadgeId);
            embedDiv.setAttribute('data-share-badge-host', 'https://www.credly.com');
            card.appendChild(embedDiv);
          } else {
            const placeholder = document.createElement('div');
            placeholder.className = 'badge-placeholder';
            placeholder.setAttribute('role', 'img');
            placeholder.setAttribute('aria-label', `${cert.name} badge`);
            placeholder.innerHTML = `
              ${cert.badgeImageUrl
                ? `<img src="${cert.badgeImageUrl}" alt="${cert.name} badge" class="badge-placeholder-img" width="150" height="150" decoding="async" />`
                : `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="badge-placeholder-icon" aria-hidden="true">
                <path d="M12 15l-2 5l1.5-1l1.5 1l1.5-1l1.5 1l-2-5" />
                <circle cx="12" cy="9" r="6" />
              </svg>`}
              <p class="badge-placeholder-name">${cert.name}</p>
              <p class="badge-placeholder-issuer">${cert.issuer}</p>
              <p class="badge-placeholder-date">Issued ${new Date(cert.issueDate + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</p>
            `;
            card.appendChild(placeholder);
          }
          certsGrid.appendChild(card);
        });
        toggleBtn.textContent = 'Show top 10 certifications';

        // Re-trigger Credly embed script
        const script = document.createElement('script');
        script.src = 'https://cdn.credly.com/assets/utilities/embed.js';
        script.async = true;
        document.body.appendChild(script);
      } else {
        // Reload page to reset to curated view (simplest approach for static site)
        window.location.hash = 'certifications';
        window.location.reload();
      }
    });
  }

  /**
   * Typewriter effect cycling through professional roles
   */
  function initTypewriter(reducedMotion: boolean): void {
    const target = document.getElementById('typewriter-target');
    const cursor = document.querySelector('.typewriter-cursor');
    if (!target) return;

    const phrases = ['Cloud Architect', 'AI Builder', 'Solutions Engineer'];

    if (reducedMotion) {
      target.textContent = phrases.join(', ');
      if (cursor) (cursor as HTMLElement).style.display = 'none';
      return;
    }

    let phraseIndex = 0;
    let charIndex = 0;
    let isDeleting = false;

    function tick(): void {
      const currentPhrase = phrases[phraseIndex];

      if (isDeleting) {
        charIndex--;
        target!.textContent = currentPhrase.substring(0, charIndex);

        if (charIndex === 0) {
          isDeleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          setTimeout(tick, 500);
          return;
        }
        setTimeout(tick, 40);
      } else {
        charIndex++;
        target!.textContent = currentPhrase.substring(0, charIndex);

        if (charIndex === currentPhrase.length) {
          isDeleting = true;
          setTimeout(tick, 1500);
          return;
        }
        setTimeout(tick, 80);
      }
    }

    tick();
  }

  /**
   * Staggered fade-in IntersectionObserver for service cards
   */
  function initStaggeredFadeIn(reducedMotion: boolean): void {
    const cards = document.querySelectorAll('.service-card-animated');
    if (!cards.length) return;

    if (reducedMotion) {
      cards.forEach(card => card.classList.add('visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
    );

    cards.forEach(card => observer.observe(card));
  }

  /**
   * Counter animation for [data-counter] elements
   */
  function animateCounter(el: HTMLElement, target: number, duration: number): void {
    const start = performance.now();

    function update(now: number): void {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // Ease-out cubic for deceleration
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      el.textContent = current + '+';

      if (progress < 1) {
        requestAnimationFrame(update);
      }
    }

    requestAnimationFrame(update);
  }

  function initCounterAnimation(reducedMotion: boolean): void {
    const counters = document.querySelectorAll('[data-counter]');
    if (!counters.length) return;

    if (reducedMotion) {
      counters.forEach(el => {
        const target = parseInt(el.getAttribute('data-target') || '0', 10);
        el.textContent = target + '+';
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.getAttribute('data-target') || '0', 10);
            animateCounter(el, target, 2000);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );

    counters.forEach(el => {
      el.textContent = '0+';
      observer.observe(el);
    });
  }

  /**
   * Parallax-lite scroll effect on hero grid
   */
  function initParallaxLite(reducedMotion: boolean): void {
    if (reducedMotion) return;

    const grid = document.querySelector('.hero-grid[data-parallax]') as HTMLElement;
    if (!grid) return;

    let ticking = false;

    function onScroll(): void {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          const offset = Math.round(scrollY * 0.3);
          grid.style.transform = `translate3d(0, ${offset}px, 0)`;
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
  }

  /**
   * Unified initialization with error boundaries
   */
  function initAllAnimations(): void {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    try { initTypewriter(reducedMotion); } catch (e) { console.warn('Typewriter init failed:', e); }
    try { initStaggeredFadeIn(reducedMotion); } catch (e) { console.warn('FadeIn init failed:', e); }
    try { initCounterAnimation(reducedMotion); } catch (e) { console.warn('Counter init failed:', e); }
    try { initParallaxLite(reducedMotion); } catch (e) { console.warn('Parallax init failed:', e); }
  }

  initSmoothScroll();
  initScrollAnimations();
  initEventTracking();
  initCertsToggle();
  initAllAnimations();

  document.addEventListener('astro:after-swap', () => {
    initSmoothScroll();
    initScrollAnimations();
    initEventTracking();
    initCertsToggle();
    initAllAnimations();
  });
</script>

<style>
  /* Scroll animation styles */
  .animate-on-scroll {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .animate-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .animate-on-scroll {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>
