---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Badge from '../components/Badge.astro';
import TimelineEntry from '../components/TimelineEntry.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import ServiceIcon from '../components/ServiceIcon.astro';
import PoweredByStrip from '../components/PoweredByStrip.astro';
import { professionalInfo } from '../data/professional';
import { certifications } from '../data/certifications';
import { careerEntries } from '../data/career';
import { testimonials } from '../data/testimonials';
import { getCuratedCertifications } from '../utils/certifications';
import '../styles/global.css';

const bioSentences = professionalInfo.bio.split('\n').filter(s => s.trim());
const curatedCerts = getCuratedCertifications(certifications);

interface ServiceCardData {
  type: 'cloud' | 'ai-automation' | 'websites' | 'payments' | 'modernization' | 'chatbots' | 'security';
  title: string;
  description: string;
  isAI: boolean;
}

const serviceCards: ServiceCardData[] = [
  { type: 'cloud', title: 'Cloud-Native Apps', description: 'Scalable, serverless applications built on AWS from the ground up.', isAI: false },
  { type: 'ai-automation', title: 'AI Process Automation', description: 'Automate back-office workflows and business processes with AI.', isAI: true },
  { type: 'websites', title: 'Websites & Portfolios', description: 'Beautiful, fast business websites and portfolio sites that convert.', isAI: false },
  { type: 'payments', title: 'Payment Integration', description: 'Stripe, payment gateways, and e-commerce solutions wired in seamlessly.', isAI: false },
  { type: 'modernization', title: 'App Modernization', description: 'Migrate and modernize legacy apps to cloud-native architectures.', isAI: false },
  { type: 'chatbots', title: 'AI Chatbots & Agents', description: 'Intelligent chatbots and AI agents that handle daily tasks for you.', isAI: true },
  { type: 'security', title: 'Secure by Design', description: 'Security-first architecture with compliance and best practices baked into every solution.', isAI: false },
];

// Generate particle data for hero background
const particles = Array.from({ length: 20 }, (_, i) => ({
  duration: 6 + (i * 0.47) % 9,
  delay: (i * 0.73) % 5,
  x: (i * 17 + 5) % 95,
  size: 2 + (i * 0.21) % 4,
  drift: -20 + (i * 2.1) % 40,
}));
---

<BaseLayout
  title="Home"
  description={`Portfolio of ${professionalInfo.name}, ${professionalInfo.title} at ${professionalInfo.employer} with ${professionalInfo.yearsExperience}+ years of experience in cloud architecture, AWS services, and modern web technologies.`}
>
  <div class="page-wrapper">
    <Header currentPath="/" />

    <main id="main-content" role="main">
      <!-- Hero Section -->
      <section class="hero" aria-label="Introduction">
        <div class="hero-bg" aria-hidden="true">
          <div class="hero-gradient"></div>
          <div class="hero-grid" data-parallax></div>
          <div class="particle-field" aria-hidden="true">
            {particles.map((p) => (
              <span
                class="particle"
                style={`--duration: ${p.duration}s; --delay: ${p.delay}s; --x: ${p.x}%; --size: ${p.size}px; --drift: ${p.drift}px;`}
              />
            ))}
          </div>
        </div>

        <div class="hero-content">

          <div class="glow-ring">
            <div class="hero-avatar">
              <img
                src="/images/profile.jpg"
                alt="Danesh Mishra - Senior Cloud Architect and Solutions Builder"
                class="avatar-img"
                width="224"
                height="224"
                decoding="async"
              />
            </div>
          </div>

          <div class="hero-badge ai-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M12 2l2.4 7.2L22 12l-7.6 2.8L12 22l-2.4-7.2L2 12l7.6-2.8z"/>
            </svg>
            AI-Augmented Development
          </div>

          <h1 class="hero-name gradient-shimmer">
            {professionalInfo.name}
          </h1>

          <p class="hero-title">
            <span class="title-role">{professionalInfo.title}</span>
            <span class="title-separator" aria-hidden="true">@</span>
            <span class="title-employer">{professionalInfo.employer}</span>
          </p>

          <div class="typewriter-container" aria-live="polite">
            <span id="typewriter-target" class="typewriter-text"></span>
            <span class="typewriter-cursor" aria-hidden="true">|</span>
          </div>

          <div class="hero-stats">
            <span class="hero-stat">
              <span class="hero-stat-number" data-counter data-target="19">19+</span>
              <span class="hero-stat-label">Years Experience</span>
            </span>
          </div>

          <p class="hero-experience">
            I help businesses build scalable cloud solutions, automate processes with AI, and modernize legacy applications.
          </p>

          <div class="hero-actions">
            <a href="/contact" class="btn btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              Get in Touch
            </a>
            <a href="/projects" class="btn btn-secondary">
              View Projects
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>
        </div>
      </section>

      <!-- Powered By Technology Strip -->
      <section class="powered-by-section" aria-label="Technologies used">
        <PoweredByStrip />
      </section>

      <!-- How I Can Help Section -->
      <section id="about" class="services-section" aria-label="Services">
        <div class="section-container">
          <h2 class="section-heading">
            <span class="heading-accent" aria-hidden="true">//</span>
            How I Can Help
          </h2>
          <p class="section-description">
            {bioSentences.map((sentence) => sentence.trim()).join(' ')}
          </p>

          <div class="services-grid">
            {serviceCards.map((card, i) => (
              <div
                class="service-card service-card-animated"
                data-service-card
                {...(card.isAI ? { 'data-ai-card': '' } : {})}
                style={`animation-delay: ${i * 100}ms;`}
              >
                <ServiceIcon service={card.type} />
                <h3 class="service-title">{card.title}</h3>
                <p class="service-desc">{card.description}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Career Timeline Section -->
      <section id="career" class="career-section" aria-label="Career Timeline">
        <div class="section-container">
          <h2 class="section-heading">
            <span class="heading-accent" aria-hidden="true">//</span>
            Career Journey
          </h2>
          <p class="section-description">
            Two decades of building enterprise solutions across three continents.
          </p>
          <div class="timeline-container">
            {careerEntries.map((entry, index) => (
              <TimelineEntry 
                entry={entry} 
                isFirst={index === 0} 
                isLast={index === careerEntries.length - 1} 
              />
            ))}
          </div>
        </div>
      </section>

      <!-- Testimonials Section -->
      <section id="testimonials" class="testimonials-section" aria-label="Testimonials">
        <div class="section-container">
          <h2 class="section-heading">
            <span class="heading-accent" aria-hidden="true">//</span>
            Recommendations
          </h2>
          <p class="section-description">
            Trusted by teams across financial services, data platforms, and cloud infrastructure.
          </p>
          <div class="testimonials-grid">
            {testimonials.map((testimonial) => (
              <TestimonialCard testimonial={testimonial} />
            ))}
          </div>
        </div>
      </section>

      <!-- Certifications Section -->
      <section id="certifications" class="certifications-section" aria-label="Certifications">
        <div class="section-container">
          <h2 class="section-heading">
            <span class="heading-accent" aria-hidden="true">//</span>
            Certifications
          </h2>
          <p class="section-description">
            Industry-recognized credentials validating cloud architecture and AWS expertise.
          </p>

          <div id="certifications-container">
            <div class="certifications-grid" id="certs-grid">
              {curatedCerts.map((cert) => (
                <Badge certification={cert} />
              ))}
            </div>
            {certifications.length > 10 && (
              <div class="certs-toggle-container">
                <button id="toggle-certs" class="btn btn-secondary certs-toggle" type="button">
                  View all {certifications.length} certifications
                </button>
              </div>
            )}
          </div>
          <script is:inline type="text/javascript" async src="https://cdn.credly.com/assets/utilities/embed.js"></script>
        </div>
      </section>

      <!-- Contact CTA Section -->
      <section id="contact" class="contact-section" aria-label="Contact">
        <div class="section-container">
          <div class="contact-card">
            <h2 class="contact-heading">Got an Idea? Let's Make It Real.</h2>
            <p class="contact-text">
              Whether it's a cloud-native app, an AI-powered workflow, or modernising something that's been around too long — I'm here to help you ship it.
            </p>
            <div class="contact-links">
              <a
                href="/contact"
                class="btn btn-primary"
                aria-label="Get in touch via contact page"
              >
                Get in Touch
              </a>
              {professionalInfo.socialLinks.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-secondary"
                  aria-label={`Connect on ${link.platform}`}
                >
                  {link.platform.charAt(0).toUpperCase() + link.platform.slice(1)}
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </div>
</BaseLayout>

<!-- Certifications toggle data -->
<script is:inline define:vars={{ allCertsJson: JSON.stringify(certifications) }}>
  // Store all certifications data for the toggle
  window.__allCertifications = JSON.parse(allCertsJson);
</script>

<style>
  /* Page Wrapper */
  .page-wrapper {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ===== HERO SECTION ===== */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100vh - 64px);
    padding: 3rem 1rem;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .hero {
      padding: 4rem 1.5rem;
    }
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(59, 130, 246, 0.08) 0%, transparent 70%),
                radial-gradient(ellipse 60% 50% at 80% 60%, rgba(99, 102, 241, 0.06) 0%, transparent 60%);
  }

  :global(.dark) .hero-gradient {
    background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(59, 130, 246, 0.12) 0%, transparent 70%),
                radial-gradient(ellipse 60% 50% at 80% 60%, rgba(99, 102, 241, 0.08) 0%, transparent 60%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 70%);
  }

  :global(.dark) .hero-grid {
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
  }

  /* Particle background */
  .particle-field {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .particle {
    position: absolute;
    bottom: -10px;
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background-color: rgba(59, 130, 246, 0.3);
    left: var(--x);
    animation: particle-float var(--duration) var(--delay) ease-in-out infinite;
  }

  :global(.dark) .particle {
    background-color: rgba(147, 197, 253, 0.2);
  }

  @keyframes particle-float {
    0% {
      transform: translate3d(0, 0, 0);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      transform: translate3d(var(--drift), -100vh, 0);
      opacity: 0;
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 100%;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .hero-content {
      max-width: 800px;
      gap: 1.5rem;
    }
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 1rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #2563eb;
    background-color: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.15);
  }

  :global(.dark) .hero-badge {
    color: #93c5fd;
    background-color: rgba(147, 197, 253, 0.08);
    border-color: rgba(147, 197, 253, 0.15);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: #22c55e;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Glow ring around avatar */
  @property --angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  .glow-ring {
    position: relative;
    display: inline-flex;
    border-radius: 50%;
    padding: 4px;
    background: conic-gradient(from var(--angle), #2563eb, #7c3aed, #2563eb);
    animation: glow-rotate 3s linear infinite;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  :global(.dark) .glow-ring {
    background: conic-gradient(from var(--angle), #60a5fa, #a78bfa, #60a5fa);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  @keyframes glow-rotate {
    to { --angle: 360deg; }
  }

  /* Avatar */
  .hero-avatar {
    width: 320px;
    height: 320px;
    border-radius: 50%;
    overflow: hidden;
    border: none;
    flex-shrink: 0;
  }

  .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-name {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #111827;
    margin: 0;
  }

  :global(.dark) .hero-name {
    color: #f9fafb;
  }

  /* Gradient shimmer on hero name */
  .gradient-shimmer {
    background: linear-gradient(
      90deg,
      #1e3a8a 0%,
      #2563eb 25%,
      #7c3aed 50%,
      #2563eb 75%,
      #1e3a8a 100%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 4s ease-in-out infinite;
  }

  :global(.dark) .gradient-shimmer {
    background: linear-gradient(
      90deg,
      #93c5fd 0%,
      #a5b4fc 25%,
      #c4b5fd 50%,
      #a5b4fc 75%,
      #93c5fd 100%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Title */
  .hero-title {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: clamp(1rem, 2.5vw, 1.375rem);
    color: #4b5563;
    margin: 0;
    line-height: 1.6;
  }

  :global(.dark) .hero-title {
    color: #9ca3af;
  }

  .title-role {
    font-weight: 600;
    color: #1e3a8a;
  }

  :global(.dark) .title-role {
    color: #93c5fd;
  }

  .title-separator {
    color: #6b7280;
    font-weight: 300;
  }

  .title-employer {
    font-weight: 600;
    background: linear-gradient(135deg, #2563eb, #7c3aed);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Experience / Value Proposition */
  .hero-experience {
    font-size: 1.0625rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.7;
    max-width: 540px;
  }

  @media (min-width: 640px) {
    .hero-experience {
      font-size: 1.125rem;
    }
  }

  :global(.dark) .hero-experience {
    color: #9ca3af;
  }

  /* Typewriter effect */
  .typewriter-container {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 1.75rem;
    font-size: 1.125rem;
    color: #6b7280;
  }

  :global(.dark) .typewriter-container {
    color: #9ca3af;
  }

  .typewriter-text {
    font-weight: 500;
    color: #2563eb;
  }

  :global(.dark) .typewriter-text {
    color: #93c5fd;
  }

  .typewriter-cursor {
    font-weight: 300;
    margin-left: 1px;
    animation: blink-cursor 0.8s step-end infinite;
    color: #2563eb;
  }

  :global(.dark) .typewriter-cursor {
    color: #93c5fd;
  }

  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Hero Stats */
  .hero-stats {
    display: flex;
    gap: 2rem;
    justify-content: center;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .hero-stat-number {
    font-size: 2rem;
    font-weight: 800;
    color: #2563eb;
    line-height: 1;
  }

  :global(.dark) .hero-stat-number {
    color: #93c5fd;
  }

  .hero-stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
  }

  :global(.dark) .hero-stat-label {
    color: #9ca3af;
  }

  /* CTA Buttons */
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s ease-out;
    min-height: 44px;
    min-width: 44px;
    border: none;
    cursor: pointer;
  }

  .btn:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .btn-primary {
    color: #ffffff;
    background: linear-gradient(135deg, #2563eb, #4f46e5);
    box-shadow: 0 1px 3px rgba(37, 99, 235, 0.3), 0 1px 2px rgba(37, 99, 235, 0.2);
  }

  .btn-primary:hover {
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4), 0 2px 6px rgba(37, 99, 235, 0.25);
    transform: translateY(-1px) scale(1.03);
  }

  .btn-secondary {
    color: #374151;
    background-color: transparent;
    border: 1.5px solid rgba(0, 0, 0, 0.15);
  }

  .btn-secondary:hover {
    border-color: #2563eb;
    color: #2563eb;
    background-color: rgba(37, 99, 235, 0.04);
    transform: scale(1.02);
  }

  :global(.dark) .btn-secondary {
    color: #d1d5db;
    border-color: rgba(255, 255, 255, 0.15);
  }

  :global(.dark) .btn-secondary:hover {
    border-color: #93c5fd;
    color: #93c5fd;
    background-color: rgba(147, 197, 253, 0.06);
    transform: scale(1.02);
  }

  /* ===== SHARED SECTION STYLES ===== */
  .section-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .section-container {
      padding: 0 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .section-container {
      padding: 0 2rem;
    }
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.75rem;
    font-weight: 700;
    color: #111827;
    margin: 0 0 2rem;
    letter-spacing: -0.02em;
  }

  @media (min-width: 768px) {
    .section-heading {
      font-size: 1.875rem;
      margin: 0 0 3rem;
    }
  }

  :global(.dark) .section-heading {
    color: #f9fafb;
  }

  .heading-accent {
    color: #2563eb;
    font-family: 'Fira Code', monospace;
    font-weight: 400;
    opacity: 0.6;
  }

  :global(.dark) .heading-accent {
    color: #60a5fa;
  }

  .section-description {
    font-size: 1rem;
    line-height: 1.7;
    color: #6b7280;
    margin: -1.5rem 0 2rem;
    max-width: 60ch;
  }

  @media (min-width: 768px) {
    .section-description {
      font-size: 1.0625rem;
      margin: -2rem 0 2.5rem;
    }
  }

  :global(.dark) .section-description {
    color: #9ca3af;
  }

  /* ===== POWERED BY STRIP ===== */
  .powered-by-section {
    padding: 1rem 1rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  :global(.dark) .powered-by-section {
    border-top-color: rgba(255, 255, 255, 0.05);
  }

  /* ===== SERVICES SECTION ===== */
  .services-section {
    padding: 3rem 1rem;
    background-color: rgba(249, 250, 251, 0.5);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  @media (min-width: 640px) {
    .services-section {
      padding: 4rem 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .services-section {
      padding: 5rem 2rem;
    }
  }

  :global(.dark) .services-section {
    background-color: rgba(17, 24, 39, 0.5);
