---
// Footer component with social links and attribution
// Validates Requirements: 12.1, 12.5

import { professionalInfo } from '../data/professional';

const currentYear = new Date().getFullYear();

// Social link icons (inline SVG for simplicity)
const socialIcons = {
  linkedin: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  github: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>`,
  youtube: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>`,
  twitter: `<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`
};

function getSocialIcon(platform: string): string {
  return socialIcons[platform as keyof typeof socialIcons] || '';
}
---

<footer class="footer" role="contentinfo">
  <div class="footer-container">
    <!-- Tagline and Contact Link -->
    <div class="footer-tagline">
      <p class="tagline">Helping businesses ship scalable cloud native, AI first software solutions faster.</p>
      <a href="/contact" class="contact-link">Get in Touch →</a>
    </div>

    <!-- Social Links -->
    <div class="social-links">
      {professionalInfo.socialLinks.map((link) => (
        <a
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="social-link"
          aria-label={`Visit ${professionalInfo.name} on ${link.platform}`}
        >
          <span class="social-icon" set:html={getSocialIcon(link.platform)} />
        </a>
      ))}
    </div>

    <!-- Copyright and Attribution -->
    <div class="footer-text">
      <p class="copyright">
        © {currentYear} {professionalInfo.name}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

<script>
  /**
   * Track footer social link clicks
   * Validates Requirements: 9.2
   */
  function initFooterTracking(): void {
    document.querySelectorAll<HTMLAnchorElement>('.footer .social-link').forEach((link) => {
      link.addEventListener('click', () => {
        const platform = link.getAttribute('aria-label')?.replace(/^Visit .+ on /, '') || 'unknown';
      });
    });
  }

  initFooterTracking();
  document.addEventListener('astro:after-swap', initFooterTracking);
</script>

<style>
  .footer {
    width: 100%;
    background-color: rgba(249, 250, 251, 0.95);
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    margin-top: auto;
    transition: background-color 0.2s ease;
  }

  :global(.dark) .footer {
    background-color: rgba(17, 24, 39, 0.95);
    border-top-color: rgba(255, 255, 255, 0.1);
  }

  .footer-container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .footer-container {
      padding: 2rem 1.5rem;
    }
  }

  @media (min-width: 768px) {
    .footer-container {
      flex-direction: row;
      justify-content: space-between;
      padding: 2.5rem 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .footer-container {
      padding: 2.5rem 2rem;
    }
  }

  /* Tagline and Contact Link */
  .footer-tagline {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    width: 100%;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  @media (min-width: 768px) {
    .footer-tagline {
      flex-direction: row;
      justify-content: center;
      gap: 1.5rem;
    }
  }

  :global(.dark) .footer-tagline {
    border-bottom-color: rgba(255, 255, 255, 0.08);
  }

  .tagline {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #374151;
    line-height: 1.5;
  }

  :global(.dark) .tagline {
    color: #d1d5db;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 600;
    color: #2563eb;
    text-decoration: none;
    padding: 0.375rem 0.75rem;
    border-radius: 6px;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .contact-link:hover {
    color: #1d4ed8;
    background-color: rgba(37, 99, 235, 0.1);
  }

  .contact-link:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  :global(.dark) .contact-link {
    color: #93c5fd;
  }

  :global(.dark) .contact-link:hover {
    color: #bfdbfe;
    background-color: rgba(147, 197, 253, 0.1);
  }

  /* Social Links */
  .social-links {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 12px;
    border-radius: 8px;
    color: #374151;
    background-color: transparent;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-link:hover {
    color: #2563eb;
    background-color: rgba(37, 99, 235, 0.1);
    transform: translateY(-2px);
  }

  .social-link:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  :global(.dark) .social-link {
    color: #d1d5db;
  }

  :global(.dark) .social-link:hover {
    color: #93c5fd;
    background-color: rgba(147, 197, 253, 0.1);
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Footer Text */
  .footer-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    .footer-text {
      flex-direction: row;
      gap: 1.5rem;
      text-align: left;
    }
  }

  .copyright,
  .attribution {
    margin: 0;
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.5;
  }

  :global(.dark) .copyright,
  :global(.dark) .attribution {
    color: #9ca3af;
  }

  .astro-link {
    color: #2563eb;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
    padding: 0.25rem 0;
    display: inline-block;
  }

  .astro-link:hover {
    color: #1d4ed8;
    text-decoration: underline;
  }

  .astro-link:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
    border-radius: 2px;
  }

  :global(.dark) .astro-link {
    color: #93c5fd;
  }

  :global(.dark) .astro-link:hover {
    color: #bfdbfe;
  }

  /* Smooth transitions */
  @media (prefers-reduced-motion: reduce) {
    .footer,
    .social-link,
    .astro-link {
      transition: none;
    }

    .social-link:hover {
      transform: none;
    }
  }
</style>
