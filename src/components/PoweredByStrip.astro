<style>
  .powered-by-strip {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem;
  }

  .powered-by-label {
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9ca3af;
  }

  :global(.dark) .powered-by-label {
    color: #6b7280;
  }

  .powered-by-logos {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
  }

  .logo-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .logo-item::after {
    content: attr(data-label);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    white-space: nowrap;
    background: #1f2937;
    color: #f9fafb;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
  }

  :global(.dark) .logo-item::after {
    background: #e5e7eb;
    color: #111827;
  }

  .logo-item:hover::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .logo-svg {
    color: #6b7280;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .logo-item:hover .logo-svg {
    opacity: 1;
  }

  :global(.dark) .logo-svg {
    color: #9ca3af;
    opacity: 0.5;
  }

  :global(.dark) .logo-item:hover .logo-svg {
    opacity: 0.9;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-svg {
      transition: none;
    }
    .logo-item::after {
      transition: none;
    }
  }
</style>
