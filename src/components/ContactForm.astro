---
/**
 * ContactForm component - Web3Forms integration with client-side validation
 * Validates Requirements: 1.4, 1.5, 1.6
 */
---

<form id="contact-form" class="contact-form" novalidate>
  <input type="hidden" name="access_key" value="a5d942d1-ec73-4444-956d-4b6144451b39" />
  <input type="hidden" name="subject" value="New enquiry from portfolio site" />
  <input type="checkbox" name="botcheck" class="visually-hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />

  <div class="form-group">
    <label for="contact-name" class="form-label">Name</label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      autocomplete="name"
      placeholder="Your name"
      class="form-input"
      aria-describedby="name-error"
    />
    <span id="name-error" class="form-error" role="alert" aria-live="polite"></span>
  </div>

  <div class="form-group">
    <label for="contact-email" class="form-label">Email</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      autocomplete="email"
      placeholder="you@example.com"
      class="form-input"
      aria-describedby="email-error"
    />
    <span id="email-error" class="form-error" role="alert" aria-live="polite"></span>
  </div>

  <div class="form-group">
    <label for="contact-message" class="form-label">Message</label>
    <textarea
      id="contact-message"
      name="message"
      required
      rows="5"
      placeholder="Tell me about your project or how I can help..."
      class="form-input form-textarea"
      aria-describedby="message-error"
    ></textarea>
    <span id="message-error" class="form-error" role="alert" aria-live="polite"></span>
  </div>

  <button type="submit" class="form-submit" id="submit-btn">
    <span class="submit-text">Send Message</span>
    <span class="submit-loading" aria-hidden="true">
      <svg class="spinner" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83" />
      </svg>
    </span>
    <svg class="submit-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="22" y1="2" x2="11" y2="13" />
      <polygon points="22 2 15 22 11 13 2 9 22 2" />
    </svg>
  </button>

  <div id="form-status" class="form-status" role="status" aria-live="polite"></div>
</form>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 560px;
  }

  /* Form group */
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    letter-spacing: 0.01em;
  }

  :global(.dark) .form-label {
    color: #d1d5db;
  }

  /* Inputs */
  .form-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    line-height: 1.5;
    color: #111827;
    background-color: rgba(255, 255, 255, 0.8);
    border: 1.5px solid rgba(0, 0, 0, 0.12);
    border-radius: 12px;
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    font-family: inherit;
    box-sizing: border-box;
  }

  .form-input::placeholder {
    color: #9ca3af;
  }

  .form-input:hover {
    border-color: rgba(37, 99, 235, 0.3);
  }

  .form-input:focus {
    border-color: #2563eb;
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    background-color: #ffffff;
  }

  :global(.dark) .form-input {
    color: #f3f4f6;
    background-color: rgba(31, 41, 55, 0.6);
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(.dark) .form-input::placeholder {
    color: #6b7280;
  }

  :global(.dark) .form-input:hover {
    border-color: rgba(96, 165, 250, 0.3);
  }

  :global(.dark) .form-input:focus {
    border-color: #60a5fa;
    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.1);
    background-color: rgba(31, 41, 55, 0.8);
  }

  /* Validation states */
  .form-input.input-error {
    border-color: #ef4444;
  }

  .form-input.input-error:focus {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  :global(.dark) .form-input.input-error {
    border-color: #f87171;
  }

  :global(.dark) .form-input.input-error:focus {
    border-color: #f87171;
    box-shadow: 0 0 0 3px rgba(248, 113, 113, 0.1);
  }

  .form-input.input-valid {
    border-color: #22c55e;
  }

  :global(.dark) .form-input.input-valid {
    border-color: #4ade80;
  }

  /* Textarea */
  .form-textarea {
    resize: vertical;
    min-height: 120px;
  }

  /* Error messages */
  .form-error {
    font-size: 0.8125rem;
    color: #ef4444;
    min-height: 1.25rem;
    line-height: 1.4;
  }

  :global(.dark) .form-error {
    color: #f87171;
  }

  /* Submit button */
  .form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.875rem 2rem;
    font-size: 1rem;
    font-weight: 600;
    color: #ffffff;
    background: linear-gradient(135deg, #2563eb, #4f46e5);
    border: none;
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    min-height: 48px;
    font-family: inherit;
    align-self: flex-start;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.25);
  }

  .form-submit:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
  }

  .form-submit:active:not(:disabled) {
    transform: translateY(0);
  }

  .form-submit:focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .form-submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  .submit-loading {
    display: none;
  }

  .form-submit.is-loading .submit-text {
    display: none;
  }

  .form-submit.is-loading .submit-icon {
    display: none;
  }

  .form-submit.is-loading .submit-loading {
    display: flex;
    align-items: center;
  }

  .spinner {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  /* Status messages */
  .form-status {
    min-height: 1.5rem;
  }

  .form-status.status-success {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #166534;
    background-color: rgba(34, 197, 94, 0.08);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 12px;
  }

  :global(.dark) .form-status.status-success {
    color: #86efac;
    background-color: rgba(34, 197, 94, 0.1);
    border-color: rgba(34, 197, 94, 0.2);
  }

  .form-status.status-error {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: #991b1b;
    background-color: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.2);
    border-radius: 12px;
  }

  :global(.dark) .form-status.status-error {
    color: #fca5a5;
    background-color: rgba(239, 68, 68, 0.1);
    border-color: rgba(239, 68, 68, 0.2);
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .form-input,
    .form-submit {
      transition: none;
    }

    .form-submit:hover:not(:disabled) {
      transform: none;
    }

    .spinner {
      animation: none;
    }
  }
</style>

<script>
  function initContactForm(): void {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    const nameInput = document.getElementById('contact-name') as HTMLInputElement;
    const emailInput = document.getElementById('contact-email') as HTMLInputElement;
    const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const statusEl = document.getElementById('form-status') as HTMLDivElement;

    const nameError = document.getElementById('name-error') as HTMLSpanElement;
    const emailError = document.getElementById('email-error') as HTMLSpanElement;
    const messageError = document.getElementById('message-error') as HTMLSpanElement;

    const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    function clearFieldError(input: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLSpanElement): void {
      input.classList.remove('input-error');
      errorEl.textContent = '';
    }

    function setFieldError(input: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLSpanElement, message: string): void {
      input.classList.add('input-error');
      input.classList.remove('input-valid');
      errorEl.textContent = message;
    }

    function setFieldValid(input: HTMLInputElement | HTMLTextAreaElement): void {
      input.classList.remove('input-error');
      input.classList.add('input-valid');
    }

    function validateName(): boolean {
      const value = nameInput.value.trim();
      if (!value) {
        setFieldError(nameInput, nameError, 'Please enter your name.');
        return false;
      }
      clearFieldError(nameInput, nameError);
      setFieldValid(nameInput);
      return true;
    }

    function validateEmail(): boolean {
      const value = emailInput.value.trim();
      if (!value) {
        setFieldError(emailInput, emailError, 'Please enter your email address.');
        return false;
      }
      if (!EMAIL_REGEX.test(value)) {
        setFieldError(emailInput, emailError, 'Please enter a valid email address.');
        return false;
      }
      clearFieldError(emailInput, emailError);
      setFieldValid(emailInput);
      return true;
    }

    function validateMessage(): boolean {
      const value = messageInput.value.trim();
      if (!value) {
        setFieldError(messageInput, messageError, 'Please enter a message.');
        return false;
      }
      clearFieldError(messageInput, messageError);
      setFieldValid(messageInput);
      return true;
    }

    // Live validation on blur
    nameInput.addEventListener('blur', validateName);
    emailInput.addEventListener('blur', validateEmail);
    messageInput.addEventListener('blur', validateMessage);

    // Clear errors on input
    nameInput.addEventListener('input', () => clearFieldError(nameInput, nameError));
    emailInput.addEventListener('input', () => clearFieldError(emailInput, emailError));
    messageInput.addEventListener('input', () => clearFieldError(messageInput, messageError));

    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();

      // Validate all fields
      const isNameValid = validateName();
      const isEmailValid = validateEmail();
      const isMessageValid = validateMessage();

      if (!isNameValid || !isEmailValid || !isMessageValid) {
        // Focus the first invalid field
        if (!isNameValid) nameInput.focus();
        else if (!isEmailValid) emailInput.focus();
        else messageInput.focus();
        return;
      }

      // Set loading state
      submitBtn.disabled = true;
      submitBtn.classList.add('is-loading');
      statusEl.className = 'form-status';
      statusEl.textContent = '';

      try {
        const formData = new FormData(form);
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (response.ok && result.success) {
          statusEl.className = 'form-status status-success';
          statusEl.innerHTML = '✓ Message sent! I\'ll get back to you soon.';
          form.reset();
          // Clear valid states
          [nameInput, emailInput, messageInput].forEach(el => el.classList.remove('input-valid'));
        } else {
          throw new Error(result.message || 'Submission failed');
        }
      } catch {
        statusEl.className = 'form-status status-error';
        statusEl.innerHTML = 'Something went wrong. Please try again or reach out via social links.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove('is-loading');
      }
    });
  }

  initContactForm();

  // Re-initialize after Astro page transitions
  document.addEventListener('astro:after-swap', initContactForm);
</script>
