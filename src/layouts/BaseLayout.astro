---
import ScrollToTop from '../components/ScrollToTop.astro';
import { generateMetaTags } from '../utils/seo/meta';
import { generatePersonSchema, generateBreadcrumbSchema } from '../utils/seo/structured-data';
import { SEO_CONFIG } from '../utils/seo/config';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
  ogType?: 'website' | 'article';
}

const { title, description, ogImage, canonicalURL, ogType } = Astro.props;

const meta = generateMetaTags({
  title,
  description,
  siteUrl: SEO_CONFIG.siteUrl,
  pathname: Astro.url.pathname,
  ogImage,
  ogType,
});

// Override canonical if explicitly provided
const canonical = canonicalURL || meta.canonicalURL;

const personSchema = generatePersonSchema();
const breadcrumbSchema = generateBreadcrumbSchema(SEO_CONFIG.siteUrl, Astro.url.pathname, title);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="152x152" href="/dbm_152.png" />
    <link rel="icon" type="image/png" sizes="120x120" href="/dbm_120.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Primary Meta Tags -->
    <title>{meta.title}</title>
    <meta name="title" content={meta.title} />
    <meta name="description" content={meta.description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />
    {SEO_CONFIG.googleSiteVerification && <meta name="google-site-verification" content={SEO_CONFIG.googleSiteVerification} />}
    
    <!-- Preconnect to external origins for faster resource loading -->
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={meta.ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={meta.ogTitle} />
    <meta property="og:description" content={meta.ogDescription} />
    <meta property="og:image" content={meta.ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Danesh Mishra" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content={meta.twitterCard} />
    <meta name="twitter:url" content={canonical} />
    <meta name="twitter:title" content={meta.twitterTitle} />
    <meta name="twitter:description" content={meta.twitterDescription} />
    <meta name="twitter:image" content={meta.twitterImage} />
    <meta name="twitter:image:alt" content={`${meta.title} - Portfolio`} />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    
    <!-- Theme Initialization Script (runs before page render to prevent flash) -->
    <script is:inline>
      const THEME_KEY = 'theme-preference';
      
      function getSystemTheme() {
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      
      function getTheme() {
        if (typeof localStorage !== 'undefined') {
          const saved = localStorage.getItem(THEME_KEY);
          if (saved === 'light' || saved === 'dark') {
            return saved;
          }
        }
        return 'dark';
      }
      
      // Apply theme immediately to prevent flash
      const theme = getTheme();
      document.documentElement.classList.add(theme);
    </script>

    <!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "8fa932d48e2a461e8a6f5d82091ba129"}'></script><!-- End Cloudflare Web Analytics -->
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
    <ScrollToTop />

    <!-- Portfolio Chatbot Widget -->
    <script is:inline>
      (function() {
        var isDev = window.location.hostname === 'localhost';
        var baseUrl = isDev ? 'http://localhost:3000' : 'https://chatbot-backend-topaz.vercel.app';
        window.ChatWidgetConfig = { apiUrl: baseUrl };
        var s = document.createElement('script');
        s.src = baseUrl + '/chat-widget.js';
        document.body.appendChild(s);
      })();
    </script>

  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 100;
    padding: 0.75rem 1.5rem;
    background-color: #2563eb;
    color: #ffffff;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 0 0 8px 8px;
    text-decoration: none;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
  }
</style>
